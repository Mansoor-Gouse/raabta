SESSION_SECRET=your-session-secret-min-32-characters-long
NEXT_PUBLIC_STREAM_API_KEY=b2cczqmbbpwg
STREAM_SECRET=87tpaz5ypq2jqqkn5hup54vhrcdfg6dv65hmmve27rheyutgdt6tjv6uej9exbs4
DEVICE_BINDING_SALT=optional-device-binding-salt

# Fixed OTP (optional): when set with ALLOW_FIXED_OTP=true or NODE_ENV!=production, this code is accepted for any phone.
# FIXED_OTP_CODE=123456
# ALLOW_FIXED_OTP=true

# Twilio Verify (optional): when TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, and TWILIO_VERIFY_SERVICE_SID are set,
# OTP is sent and checked via Twilio Verify API. Omit these to use local MongoDB OTP (dev / no SMS).
# Create a Verify Service at https://console.twilio.com/ — enable SMS to your target countries (e.g. India +91).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# Default country code for E.164 when storing 10-digit numbers (default 91).
# TWILIO_DEFAULT_COUNTRY_CODE=91
# Force provider: twilio | local (optional; default: twilio if Twilio env is complete, else local)
# OTP_PROVIDER=

# Web Push (optional): generate with npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY for client-side push subscribe
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
