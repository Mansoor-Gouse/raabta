MONGODB_URI=mongodb://localhost:27017/messaging
SESSION_SECRET=your-session-secret-min-32-characters-long
NEXT_PUBLIC_STREAM_API_KEY=b2cczqmbbpwg
STREAM_SECRET=87tpaz5ypq2jqqkn5hup54vhrcdfg6dv65hmmve27rheyutgdt6tjv6uej9exbs4
DEVICE_BINDING_SALT=optional-device-binding-salt

# Fixed OTP (optional): when set with ALLOW_FIXED_OTP=true or NODE_ENV!=production, this code is accepted for any phone.
# FIXED_OTP_CODE=123456
# ALLOW_FIXED_OTP=true

# Twilio Verify (optional): when TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, and TWILIO_VERIFY_SERVICE_SID are set,
# OTP is sent and checked via Twilio Verify API. Omit these to use local MongoDB OTP (dev / no SMS).
# Create a Verify Service at https://console.twilio.com/ — enable WhatsApp and/or SMS for your countries (e.g. India +91).
# WhatsApp: connect WhatsApp sender in Twilio (Messaging / WhatsApp) — see Twilio Verify + WhatsApp docs.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# Delivery channel: whatsapp (default) or sms
# TWILIO_VERIFY_CHANNEL=whatsapp
# Default country code for E.164 when storing 10-digit numbers (default 91).
# TWILIO_DEFAULT_COUNTRY_CODE=91
# Force provider: twilio | local (optional; default: twilio if Twilio env is complete, else local)
# OTP_PROVIDER=

# Skip all OTP validation (no SMS, any 6-digit code works). NEVER enable in production.
# SKIP_OTP_VALIDATION=true

# Firebase Phone OTP (optional): Auth-only — SMS + code via Firebase; server still uses iron-session + MongoDB.
# Console: enable Phone sign-in; add authorized domains (localhost + production).
# Never paste real keys or service-account JSON into this file — use .env.local (gitignored) only.
# NEXT_PUBLIC_USE_FIREBASE_PHONE_OTP=true
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# FIREBASE_SERVICE_ACCOUNT_JSON=  # server-only: one-line JSON from Firebase Console → Project settings → Service accounts → Generate new private key
# Web Push (optional): generate with npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY for client-side push subscribe
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
